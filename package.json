{
    "name": "@bric/rex-default-page",
    "version": "0.0.1",
    "description": "REX module that sets the default page for new tabs and open windows.",
    "keywords": [
        "extension",
        "rex"
    ],
    "author": "Behavioral Research Innovation Center",
    "type": "module",
    "homepage": "https://github.com/bric-digital/rex-default-page",
    "bugs": {
        "url": "https://github.com/bric-digital/rex-default-page/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bric-digital/rex-default-page.git"
    },
    "exports": {
        "./service-worker": "./src/service-worker.mts"
    },
    "scripts": {
        "build": "tsc",
        "lint": "eslint src",
        "pretest": "node tests/scripts/build-test-bundle.js",
        "test": "playwright test",
        "test:ci": "playwright test --reporter=dot",
        "test:debug": "playwright test --debug",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:unit": "playwright test specs/"
    },
    "dependencies": {
        "@bric/rex-core": "github:bric-digital/rex-core"
    }
}
